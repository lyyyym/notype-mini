{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NoType Mini",
  "version": "0.1.0",
  "identifier": "com.yiming.notype-mini",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NoType Mini",
        "width": 700,
        "height": 500,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      },
      {
        "label": "bubble",
        "title": "",
        "width": 360,
        "height": 200,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focusable": false,
        "transparent": true,
        "resizable": false,
        "shadow": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "frameworks": [],
      "minimumSystemVersion": "13.0"
    }
  }
}
